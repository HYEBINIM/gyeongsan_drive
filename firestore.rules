rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 관리자 확인 함수
    function isAdmin(uid) {
      return exists(/databases/$(database)/documents/adminRoles/$(uid)) &&
             get(/databases/$(database)/documents/adminRoles/$(uid)).data.role in ['admin', 'superAdmin'];
    }

    // 기본 거부 정책
    match /{document=**} {
      allow read, write: if false;
    }

    // 관리자 역할 (읽기만 가능, 쓰기는 콘솔에서만)
    match /adminRoles/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // 공지사항 (모든 사용자 읽기, 관리자만 쓰기)
    match /announcements/{announcementId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && isAdmin(request.auth.uid);
    }

    // 문의사항 (사용자 작성, 관리자 답변)
    match /inquiries/{inquiryId} {
      allow read: if request.auth != null &&
                  (request.auth.uid == resource.data.userId || isAdmin(request.auth.uid));
      allow create: if request.auth != null &&
                    request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && isAdmin(request.auth.uid);
      allow delete: if request.auth != null &&
                    request.auth.uid == resource.data.userId &&
                    resource.data.status == 'pending';
    }

    // 사용자 데이터
    match /users/{uid} {
      // 본인의 데이터만 읽기/쓰기 가능 (이메일 인증 필수)
      allow read, write: if request.auth != null
                         && request.auth.uid == uid
                         && request.auth.token.email_verified == true;
      // 관리자는 모든 사용자 데이터 읽기 가능
      allow read: if request.auth != null && isAdmin(request.auth.uid);

      // 차량 서브컬렉션
      match /vehicles/{vehicleId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == uid
                           && request.auth.token.email_verified == true;

        // 차량 데이터 검증
        allow create, update: if request.resource.data.keys().hasAll([
          'vehicleNumber', 'region', 'modelName', 'fuelType',
          'mtId', 'registeredAt', 'isActive'
        ])
        && request.resource.data.vehicleNumber is string
        && request.resource.data.vehicleNumber.size() > 0
        && request.resource.data.region is string
        && request.resource.data.region.size() > 0
        && request.resource.data.modelName is string
        && request.resource.data.modelName.size() > 0
        && request.resource.data.fuelType is string
        && request.resource.data.fuelType.size() > 0
        && request.resource.data.mtId is string
        && request.resource.data.mtId.size() > 0
        && request.resource.data.registeredAt is number
        && request.resource.data.isActive is bool;
      }

      // 안심귀가 설정 서브컬렉션
      match /safe_home_settings/{docId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == uid
                           && request.auth.token.email_verified == true;
      }
    }

    // 차량 마스터 데이터 (읽기 전용)
    match /cars/{carId} {
      allow read: if request.auth != null
                  && request.auth.token.email_verified == true;
      allow write: if false;
    }

    // 차량 번호 매핑 (읽기 전용)
    match /vehicleMappings/{vehicleNumber} {
      allow read: if request.auth != null
                  && request.auth.token.email_verified == true;
      allow write: if false;
    }

    // 이메일 인덱스
    match /emailIndex/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.email_verified == true;
    }

    // 계정 삭제 요청 (누구나 요청 생성, 관리자만 읽기/수정)
    match /accountDeletionRequests/{requestId} {
      // 누구나 요청 생성 가능 (pending 상태만)
      allow create: if request.resource.data.status == 'pending';
      // 관리자만 읽기/수정 가능
      allow read, update: if request.auth != null && isAdmin(request.auth.uid);
      // 삭제는 불가 (기록 보존)
      allow delete: if false;
    }

    // 약관 (공개 읽기, 쓰기 불가)
    match /terms/{termType} {
      allow read: if true;
      allow write: if false;
    }

    // 도로 상태 정보 (공개 읽기, 쓰기 불가 - Cloud Functions에서만 쓰기)
    match /road_conditions/{conditionId} {
      allow read: if true;
      allow write: if false;
    }

    // 지역 정보 (공개 읽기, 쓰기 불가)
    match /region_info/{category} {
      allow read: if true;
      allow write: if false;

      // 하위 장소 컬렉션
      match /items/{placeId} {
        allow read: if true;
        allow write: if false;
      }
    }
  }
}
