# ============================================
# Environment Variables Template
# ============================================
# Copy this file to .env and fill in the actual values
# DO NOT commit .env file to version control!
# ============================================

# --------------------------------------------
# Kakao API
# --------------------------------------------
# Kakao REST API Key for local search and geocoding
# Get your key from: https://developers.kakao.com/
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# --------------------------------------------
# MCP Server
# --------------------------------------------
# MCP server endpoint URL (Streamable HTTP/SSE)
MCP_SERVER_URL=https://your-mcp-server-domain.com/mcp

# Auth token for MCP server (Token value without "Token " prefix)
MCP_AUTH_TOKEN=your_mcp_auth_token_here

# --------------------------------------------
# Voice Command API
# --------------------------------------------
# URL for voice command processing API
VOICE_COMMAND_API_URL=https://your-voice-api-domain.com/chat

# Token for voice command API authentication
VOICE_COMMAND_API_TOKEN=your_voice_api_token_here

# Auth string for voice command API
VOICE_COMMAND_API_AUTH=your_voice_api_auth_here

# ============================================
# Native SDK Keys (for reference)
# ============================================
# These keys are configured in native files:
#
# [Android] android/app/src/main/AndroidManifest.xml
# - Naver Map NCP_KEY_ID
#
# [iOS] ios/Runner/Info.plist
# - Naver Map NMFClientId (if applicable)
#
# [Firebase]
# - google-services.json (Android)
# - GoogleService-Info.plist (iOS)
# - lib/firebase_options.dart
# ============================================
